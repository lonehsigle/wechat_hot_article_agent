# ============================================
# 生产环境配置文件
# ============================================
# 复制此文件为 .env.production 并填入真实值
# 复制命令: cp .env.production.example .env.production

# ============================================
# 加密密钥 (必须设置)
# ============================================
# 生成命令: openssl rand -base64 32
# 警告: 修改后之前加密的数据将无法解密！
DB_ENCRYPTION_KEY=your_production_encryption_key_here

# ============================================
# 微信公众号 API 配置 (必须设置)
# ============================================
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_AUTHOR=默认作者名称

# ============================================
# LLM API Keys
# ============================================
# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI (可选)
OPENAI_API_KEY=your_openai_api_key

# ============================================
# 图片源 API Keys
# ============================================
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key

# ============================================
# 搜索服务 API Keys
# ============================================
EXA_API_KEY=your_exa_api_key
TAVILY_API_KEY=your_tavily_api_key
TIANGONG_API_KEY=your_tiangong_api_key

# ============================================
# 数据库配置
# ============================================
DATABASE_PATH=/app/data/content-monitor.db
